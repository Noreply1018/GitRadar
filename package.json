{
  "name": "gitradar",
  "version": "2.0.0",
  "license": "MIT",
  "private": false,
  "description": "Personal GitHub open-source discovery radar.",
  "scripts": {
    "generate:digest": "tsx src/commands/generate-daily-digest.ts",
    "generate:digest:send": "tsx src/commands/generate-daily-digest.ts --send",
    "analyze:digest": "tsx src/commands/analyze-digest.ts",
    "feedback:list": "tsx src/commands/list-feedback.ts",
    "validate:digest-rules": "tsx src/commands/validate-digest-rules.ts",
    "send:wecom:sample": "tsx src/commands/send-wecom-sample.ts",
    "dev:web": "vite --config web/vite.config.ts",
    "dev:web-api": "tsx src/web-api/server.ts",
    "start:console": "tsx src/web-api/server.ts",
    "start:console:docker": "tsx src/web-api/server.ts --host 0.0.0.0 --port 3210",
    "build:web": "vite build --config web/vite.config.ts",
    "format:check": "prettier --check .",
    "lint:md": "markdownlint README.md SECURITY.md SUPPORT.md CONTRIBUTING.md .github/**/*.md docs/**/*.md config/**/*.md data/**/*.md scripts/**/*.md src/**/*.md",
    "lint:yaml": "prettier --check \"**/*.{yml,yaml}\"",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && npm run typecheck:web",
    "typecheck:web": "tsc -p web/tsconfig.json --noEmit"
  },
  "dependencies": {
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@types/node": "24.5.2",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitejs/plugin-react": "5.1.0",
    "dotenv": "17.2.2",
    "markdownlint-cli": "0.48.0",
    "prettier": "3.6.2",
    "tsx": "4.20.5",
    "typescript": "5.9.2",
    "undici": "7.24.5",
    "vite": "7.1.7",
    "vitest": "3.2.4"
  }
}
